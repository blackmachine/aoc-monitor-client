{
  "name": "Main Terminal Scene",
  "version": "1.0",
  "assets": {
    "atlases": {
      "c64": "assets/c64.json",
      "c64inv": "assets/c64inv.json",
      "plex": "assets/plexmono32x64.json"
    },
"scripts": { "basis": "assets/basis.rhai"   },
    "shaders": {
      "chromatic": "assets/chromatic.fs",
	"scanline": "assets/scanline.fs",
"bloom": "assets/glow.fs"
    }
  },
  "glyphsets": {
    "flexmono": {
      "base": "plex",
      "merges": []
    },

    "composite": {
      "base": "c64",
      "merges": ["c64inv"]
    }
  },
  "scene": {
    "nodes": [
      {
        "id": "main_buf",
        "type": "buffer",
        "name": "main",
        "width": 64,
        "height": 32,
        "glyphset": "composite",
        "z_index": 1,
        "dynamic": false,
	"shaders": ["scanline"]
      },
      {
        "id": "back_buf",
        "type": "buffer",
        "name": "back",
        "width": 32,
        "height": 16,
        "glyphset": "flexmono",
        "z_index": -1,
        "dynamic": true,
        "parent": "main_buf",
        "shaders": ["scanline"]
      }    ]
  }
}